@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Nav

<MudLayout>

    <!-- SIDEBAR -->
    <MudDrawer Open="true"
               Variant="DrawerVariant.Persistent"
               Elevation="2"
               Style="background: linear-gradient(180deg, #132d6e 0%, #1a3572 60%, #1e3a8a 100%); border-right: 1px solid rgba(255,255,255,0.08);">

        <MudDrawerHeader Style="padding: 48px 16px 24px; border-bottom: 1px solid rgba(255,255,255,0.08);">
            <div style="display:flex; flex-direction:column; align-items:center; width:100%; text-align:center;">
                <MudImage Src="/images/logo.jpg" Alt="ACLC Logo" Width="70" Height="70"
                          Style="border-radius: 14px; filter: drop-shadow(0 2px 10px rgba(0,0,0,0.4)); margin-bottom: 14px;" />
                <MudText Typo="Typo.h5" Style="color:#ffffff; font-weight:900; letter-spacing:3px; line-height:1; margin-bottom:0px;">
                    ACLC
                </MudText>
                <MudText Typo="Typo.h5" Style="color:#e8253a; font-weight:900; letter-spacing:3px; line-height:1; margin-bottom:6px;">
                    COLLEGE
                </MudText>
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.75); font-weight:600; letter-spacing:3px; font-size:10px; margin-bottom:14px;">
                    MANDAUE CITY
                </MudText>
                <div style="width:40px; height:2px; background:#cc1f2e; border-radius:2px; margin-bottom:10px;"></div>
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4); font-size:9px; letter-spacing:2.5px; text-transform:uppercase;">
                    @(_user?.Role) Portal
                </MudText>
            </div>
        </MudDrawerHeader>

        <MudNavMenu Style="padding: 12px 0;">

            @if (_user?.Role == "Admin")
            {
                <MudText Typo="Typo.caption"
                         Style="color:rgba(255,255,255,0.3); letter-spacing:3px; text-transform:uppercase; padding: 16px 20px 6px; font-size:10px;">
                    Main
                </MudText>
                <MudNavLink Href="/admin" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Dashboard"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Dashboard
                </MudNavLink>
                <MudNavLink Href="/admin/pending-enrollments"
                            Icon="@Icons.Material.Filled.HowToReg"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Pending Enrollments
                </MudNavLink>
                <MudNavLink Href="/admin/pending-documents"
                            Icon="@Icons.Material.Filled.Description"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Documents
                </MudNavLink>
                <MudNavLink Href="/admin/create-student-account"
                            Icon="@Icons.Material.Filled.PersonAdd"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Create Student
                </MudNavLink>
                <MudNavLink Href="/admin/all-students"
                            Icon="@Icons.Material.Filled.People"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Students
                </MudNavLink>
            }
            else if (_user?.Role == "Registrar")
            {
                <MudText Typo="Typo.caption"
                         Style="color:rgba(255,255,255,0.3); letter-spacing:3px; text-transform:uppercase; padding: 16px 20px 6px; font-size:10px;">
                    Main
                </MudText>
                <MudNavLink Href="/registrar" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Dashboard"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Dashboard
                </MudNavLink>
                <MudNavLink Href="/registrar/pending-enrollment"
                            Icon="@Icons.Material.Filled.Assignment"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Pending Enrollment
                </MudNavLink>
                <MudNavLink Href="/registrar/grades"
                            Icon="@Icons.Material.Filled.School"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Grades
                </MudNavLink>
            }
            else if (_user?.Role == "Cashier")
            {
                <MudText Typo="Typo.caption"
                         Style="color:rgba(255,255,255,0.3); letter-spacing:3px; text-transform:uppercase; padding: 16px 20px 6px; font-size:10px;">
                    Main
                </MudText>
                <MudNavLink Href="/cashier" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Dashboard"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Dashboard
                </MudNavLink>
                <MudNavLink Href="/cashier/pending-payments"
                            Icon="@Icons.Material.Filled.Payments"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Pending Payments
                </MudNavLink>
                <MudNavLink Href="/cashier/all-payments"
                            Icon="@Icons.Material.Filled.ReceiptLong"
                            Style="color:rgba(255,255,255,0.85); border-radius:10px; margin: 2px 10px;">
                    Payments
                </MudNavLink>
            }

        </MudNavMenu>

        <MudSpacer />
        <MudStack Style="padding: 16px;">
            <MudButton FullWidth="true"
                       Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Logout"
                       OnClick="Logout"
                       Style="color:rgba(255,255,255,0.6); border-color:rgba(255,255,255,0.15); border-radius:10px; text-transform:uppercase; letter-spacing:1px; font-size:12px;">
                Logout
            </MudButton>
        </MudStack>

    </MudDrawer>

    <!-- MAIN CONTENT -->
    <MudMainContent Style="background:#f0f4ff; min-height:100vh; padding:0 !important;">

        <!-- TOP APPBAR -->
        <MudAppBar Elevation="0" Fixed="false"
                   Style="background:#ffffff; border-bottom:1px solid #e8edf5; position:sticky; top:0; z-index:100;">
            <MudText Typo="Typo.h6" Style="color:#132d6e; font-weight:700;">
                @_pageTitle
            </MudText>
            <MudSpacer />
            <MudText Typo="Typo.body2" Style="color:#6b7a99; margin-right:12px;">
                Academic Year 2025 – 2026
            </MudText>
            <MudChip T="string" Size="Size.Small"
                     Style="background:#eef2ff; color:#132d6e; font-weight:600; border:1px solid #c7d2f0; margin-right:8px;">
                @_user?.Role
            </MudChip>
            <MudAvatar Style="background:#cc1f2e; color:white; font-weight:700;" Size="Size.Small">
                @(_user?.Username?.Length > 0 ? _user.Username[0].ToString().ToUpper() : "A")
            </MudAvatar>
        </MudAppBar>

        <!-- PAGE BODY -->
        <MudContainer MaxWidth="MaxWidth.False" Style="padding: 28px 32px;">
            @Body
        </MudContainer>

    </MudMainContent>

</MudLayout>

<style>
    .mud-drawer {
        width: 240px !important;
        min-width: 240px !important;
        top: 0 !important;
        height: 100vh !important;
        position: fixed !important;
        left: 0 !important;
        z-index: 1200 !important;
        display: flex !important;
        flex-direction: column !important;
    }

    .mud-drawer-content {
        width: 240px !important;
        min-width: 240px !important;
        height: 100% !important;
        display: flex !important;
        flex-direction: column !important;
        overflow-y: auto !important;
        overflow-x: hidden !important;
    }

    .mud-main-content {
        margin-left: 240px !important;
        padding: 0 !important;
        background: #f0f4ff !important;
        min-height: 100vh !important;
    }

    .mud-appbar {
        left: 240px !important;
        width: calc(100% - 240px) !important;
        background: #ffffff !important;
        border-bottom: 1px solid #e8edf5 !important;
        box-shadow: none !important;
    }

    .mud-nav-link.active {
        background-color: rgba(0, 114, 206, 0.25) !important;
        border-left: 3px solid #0072CE !important;
        color: #ffffff !important;
        font-weight: 600 !important;
    }

    .mud-nav-link:hover {
        background-color: rgba(255,255,255,0.10) !important;
    }

    /* Fix drawer header centering */
    .mud-drawer-header {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        width: 100% !important;
        padding: 0 !important;
    }
</style>

@code {
    private UserInfo? _user;

    private string _pageTitle => Nav.Uri switch
    {
        var u when u.EndsWith("/admin") => "Dashboard",
        var u when u.Contains("pending-enrollments") => "Pending Enrollments",
        var u when u.Contains("pending-documents") => "Documents",
        var u when u.Contains("create-student-account") => "Create Student Account",
        var u when u.Contains("all-students") => "All Students",
        var u when u.EndsWith("/registrar") => "Dashboard",
        var u when u.Contains("registrar/pending-enrollment") => "Pending Enrollment",
        var u when u.Contains("registrar/grades") => "Grades",
        var u when u.EndsWith("/cashier") => "Dashboard",
        var u when u.Contains("pending-payments") => "Pending Payments",
        var u when u.Contains("all-payments") => "Payments",
        _ => "Dashboard"
    };

    protected override async Task OnInitializedAsync()
    {
        _user = await AuthService.GetCurrentUserAsync();
        if (_user == null) Nav.NavigateTo("/login");
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}