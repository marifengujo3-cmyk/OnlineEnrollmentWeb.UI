@page "/cashier/pending-payments"
@layout MainLayout
@inject PaymentService PaymentService
@inject ISnackbar Snackbar

<PageTitle>Pending Payments - GCash Verification</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h6" Style="color:#132d6e; font-weight:700;">Pending Payments</MudText>
        <MudText Typo="Typo.body2" Style="color:#6b7a99;">
            Total: @_filteredTotal payment(s) | Showing @_pagedPayments.Count of @_filteredTotal
        </MudText>
    </MudStack>
    <MudChip T="string" Style="background:#fff3cd; color:#856404; font-weight:600; border:1px solid #ffc107;">
        <MudIcon Icon="@Icons.Material.Filled.Payments" Style="font-size:1rem; margin-right:4px;" />
        @_filteredTotal Pending
    </MudChip>
</MudStack>

<!-- Search Bar -->
<MudPaper Elevation="0" Style="border-radius:14px; border:1px solid #e2e8f4; padding:16px; margin-bottom:24px;">
    <MudTextField @bind-Value="_searchTerm"
                  Placeholder="Search by Student #, Name, or Reference #..."
                  Variant="Variant.Outlined"
                  Size="Size.Small"
                  Style="width:100%;"
                  Immediate="true"
                  OnKeyUp="@(() => ApplyFilters())">
        <Adornment>
            <MudIcon Icon="@Icons.Material.Filled.Search" />
        </Adornment>
    </MudTextField>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_filteredTotal == 0)
{
    <MudPaper Elevation="0" Style="border-radius:14px; border:1px solid #e2e8f4; padding:48px; text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.Payments" Style="font-size:3rem; color:#c7d2f0;" />
        <MudText Style="color:#6b7a99; margin-top:16px;">No pending payments found</MudText>
    </MudPaper>
}
else
{
    <MudPaper Elevation="2" Style="border-radius:14px; overflow-x:auto;">
        <MudTable Items="_pagedPayments" Hover="true" Elevation="0" Style="min-width:1100px;">
            <HeaderContent>
                <MudTh>Student ID</MudTh>
                <MudTh>Student #</MudTh>
                <MudTh>Full Name</MudTh>
                <MudTh>Course</MudTh>
                <MudTh>Year Level</MudTh>
                <MudTh>Semester</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Method</MudTh>
                <MudTh>Reference #</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.StudentID</MudTd>
                <MudTd>@context.StudentNumber</MudTd>
                <MudTd>@context.FullName</MudTd>
                <MudTd>@context.Course</MudTd>
                <MudTd>@context.YearLevel</MudTd>
                <MudTd>@context.Semester</MudTd>
                <MudTd style="font-weight:600; color:#2e7d32;">₱@context.Amount.ToString("N2")</MudTd>
                <MudTd>
                    <MudChip T="string" Color="@(context.PaymentMethod == "GCash" ? Color.Info : Color.Warning)" Size="Size.Small">
                        @context.PaymentMethod
                    </MudChip>
                </MudTd>
                <MudTd>
                    <div style="font-family:monospace; font-weight:500;">@context.ReferenceNumber</div>
                </MudTd>
                <MudTd>@context.PaymentDate.ToString("MMM dd, yyyy HH:mm")</MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <MudButton Variant="Variant.Filled"
                                   Size="Size.Small"
                                   Color="Color.Success"
                                   OnClick="@(() => ApprovePayment(context))"
                                   Disabled="_processingIds.Contains(context.PaymentID)">
                            Approve
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => RejectPayment(context))"
                                   Disabled="_processingIds.Contains(context.PaymentID)">
                            Reject
                        </MudButton>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
        
        <!-- Pagination Controls -->
        <div style="display: flex; justify-content: center; align-items: center; gap: 16px; margin-top: 16px; margin-bottom: 16px; padding: 8px;">
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => ChangePage(_currentPage - 1))" Disabled="@(_currentPage <= 1)">
                ◀ Previous
            </MudButton>
            
            <span style="font-size: 14px; color: #6b7a99;">
                Page @_currentPage of @_totalPages
            </span>
            
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => ChangePage(_currentPage + 1))" Disabled="@(_currentPage >= _totalPages)">
                Next ▶
            </MudButton>
            
            <div style="margin-left: 16px;">
                <select @bind="PageSize" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 8px;">
                    <option value="10">10 per page</option>
                    <option value="20">20 per page</option>
                    <option value="50">50 per page</option>
                    <option value="100">100 per page</option>
                </select>
            </div>
        </div>
    </MudPaper>
}

@code {
    private List<PaymentModel> _allPayments = new();
    private List<PaymentModel> _filteredPayments = new();
    private List<PaymentModel> _pagedPayments = new();
    private HashSet<int> _processingIds = new();
    private bool _loading = true;
    private string _searchTerm = "";
    
    // Counts
    private int _filteredTotal = 0;
    
    // Pagination
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalPages = 1;

    private int PageSize
    {
        get => _pageSize;
        set
        {
            if (_pageSize != value)
            {
                _pageSize = value;
                ChangePage(1);
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPayments();
    }

    private async Task LoadPayments()
    {
        _loading = true;
        StateHasChanged();
        
        var response = await PaymentService.GetPendingPaymentsAsync(_searchTerm);
        if (response.Status == 200 && response.Data != null)
        {
            _allPayments = response.Data;
        }
        else
        {
            _allPayments = new List<PaymentModel>();
        }
        
        ApplyFilters();
        _loading = false;
        StateHasChanged();
    }

    private void ApplyFilters()
    {
        var query = _allPayments.AsEnumerable();
        
        // Search filter
        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            query = query.Where(p =>
                (p.FullName?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.StudentNumber?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.ReferenceNumber?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
        }
        
        _filteredPayments = query.OrderByDescending(p => p.PaymentDate).ToList();
        _filteredTotal = _filteredPayments.Count;
        
        // Calculate total pages
        _totalPages = (int)Math.Ceiling((double)_filteredTotal / _pageSize);
        
        // Ensure current page is valid
        if (_currentPage > _totalPages && _totalPages > 0)
            _currentPage = _totalPages;
        if (_currentPage < 1)
            _currentPage = 1;
        
        // Apply pagination
        _pagedPayments = _filteredPayments
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
            
        StateHasChanged();
    }

    private void ChangePage(int newPage)
    {
        if (newPage < 1 || newPage > _totalPages) return;
        _currentPage = newPage;
        ApplyFilters();
    }

    private async Task ApprovePayment(PaymentModel payment)
    {
        _processingIds.Add(payment.PaymentID);
        StateHasChanged();
        
        var result = await PaymentService.ApprovePaymentAsync(payment.PaymentID);
        Snackbar.Add(result.Status == 200 ? $"Payment approved for {payment.FullName}!" : $"Error: {result.Message}",
                     result.Status == 200 ? Severity.Success : Severity.Error);
        
        _processingIds.Remove(payment.PaymentID);
        if (result.Status == 200)
        {
            await LoadPayments();
        }
    }

    private async Task RejectPayment(PaymentModel payment)
    {
        _processingIds.Add(payment.PaymentID);
        StateHasChanged();
        
        var result = await PaymentService.RejectPaymentAsync(payment.PaymentID);
        Snackbar.Add(result.Status == 200 ? $"Payment rejected for {payment.FullName}" : $"Error: {result.Message}",
                     result.Status == 200 ? Severity.Warning : Severity.Error);
        
        _processingIds.Remove(payment.PaymentID);
        if (result.Status == 200)
        {
            await LoadPayments();
        }
    }
}