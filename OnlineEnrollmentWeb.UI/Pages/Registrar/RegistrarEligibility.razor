@page "/registrar/eligibility"
@layout MainLayout
@inject EligibilityService EligibilityService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h5" Style="color:#132d6e; font-weight:700; margin-bottom:16px;">
    Student Eligibility Management
</MudText>

<!-- Filter Section -->
<div class="filter-bar">
    <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">

        <!-- School Year Filter -->
        <select @bind="_schoolYear" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; width: 200px;">
            <option value="2026-2027">2026-2027</option>
        </select>

        <!-- Semester Filter -->
        <select @bind="_semester" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; width: 180px;">
            <option value="2nd Semest">2nd Semester</option>
            <option value="1st Semest">1st Semester</option>
        </select>

        <!-- Course Filter - NEW -->
        <select @bind="_selectedCourse" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; width: 220px;">
            <option value="">All Courses</option>
            <option value="BS Information Technology">BS Information Technology</option>
            <option value="BS Computer Science">BS Computer Science</option>
            <option value="BS Accountancy">BS Accountancy</option>
            <option value="BS Business Administration">BS Business Administration</option>
            <option value="BS Hospitality Management">BS Hospitality Management</option>
        </select>

        <!-- Year Level Filter - NEW -->
        <select @bind="_selectedYearLevel" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; width: 150px;">
            <option value="0">All Years</option>
            <option value="1">1st Year</option>
            <option value="2">2nd Year</option>
            <option value="3">3rd Year</option>
            <option value="4">4th Year</option>
        </select>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@LoadStudents">Load Students</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="@ClearFilters">Clear Filters</MudButton>
    </div>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_filteredStudents.Count == 0)
{
    <MudPaper Style="border-radius:14px; padding:48px; text-align:center;">
        <MudText>No students found</MudText>
    </MudPaper>
}
else
{
    <!-- Result Count -->
    <div style="margin-bottom: 16px;">
        <MudText Typo="Typo.body2" Style="color:#666;">
            Showing @_filteredStudents.Count of @_students.Count students
        </MudText>
    </div>

    <table class="eligibility-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Student #</th>
                <th>Name</th>
                <th>Course</th>
                <th>Year</th>
                <th style="text-align:center;">Grades</th>
                <th style="text-align:center;">Clearance</th>
                <th style="text-align:center;">Payment</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in _filteredStudents)
            {
                <tr>
                    <td>@student.StudentID</td>
                    <td>@student.StudentNumber</td>
                    <td>@student.FullName</td>
                    <td>@student.Course</td>
                    <td>@student.YearLevel</td>
                    <td style="text-align:center;">
                        <label class="switch">
                            <input type="checkbox" @bind="student.IsGradeCleared" />
                            <span class="slider"></span>
                        </label>
                    </td>
                    <td style="text-align:center;">
                        <label class="switch">
                            <input type="checkbox" @bind="student.IsClearanceCleared" />
                            <span class="slider"></span>
                        </label>
                    </td>
                    <td style="text-align:center;">
                        <label class="switch">
                            <input type="checkbox" @bind="student.IsPaymentCleared" />
                            <span class="slider"></span>
                        </label>
                    </td>
                    <td>
                        @if (student.IsGradeCleared && student.IsClearanceCleared && student.IsPaymentCleared)
                        {
                            <span class="badge-eligible">✓ Eligible</span>
                        }
                        else
                        {
                            <span class="badge-noteligible">✗ Not Eligible</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div style="display: flex; justify-content: flex-end; margin-top: 20px;">
        <button class="save-btn" @onclick="SaveAllStudents">
            SAVE ALL CHANGES
        </button>
    </div>
}

<style>
    .eligibility-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        .eligibility-table th {
            background: #132d6e;
            color: white;
            padding: 12px;
            text-align: left;
            font-weight: 600;
        }

        .eligibility-table td {
            padding: 10px 12px;
            border-bottom: 1px solid #e0e0e0;
        }

        .eligibility-table tr:hover {
            background: #f5f5f5;
        }

    .switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 24px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: 0.3s;
        border-radius: 24px;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: 0.3s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background-color: #4caf50;
    }

        input:checked + .slider:before {
            transform: translateX(26px);
        }

    .badge-eligible {
        background: #4caf50;
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
    }

    .badge-noteligible {
        background: #f44336;
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
    }

    .filter-bar {
        background: white;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 24px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }

    .save-btn {
        background: #132d6e;
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        margin-top: 20px;
        float: right;
    }

        .save-btn:hover {
            background: #1e3a8a;
        }
</style>

@code {
    private List<RegistrarEligibilityModel> _students = new();
    private List<RegistrarEligibilityModel> _filteredStudents = new();
    private bool _loading = false;
    private string _schoolYear = "2026-2027";
    private string _semester = "2nd Semest";
    private string _selectedCourse = "";
    private int _selectedYearLevel = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
    }

    private async Task LoadStudents()
    {
        _loading = true;
        StateHasChanged();

        var response = await EligibilityService.GetStudentsForRegistrarAsync(_schoolYear, _semester);

        if (response.Status == 200 && response.Data != null && response.Data.Count > 0)
        {
            _students = response.Data;
            ApplyFilters();
            Snackbar.Add($"Loaded {_students.Count} students", Severity.Success);
        }
        else
        {
            _students = new List<RegistrarEligibilityModel>();
            _filteredStudents = new List<RegistrarEligibilityModel>();
            Snackbar.Add("No students found", Severity.Warning);
        }

        _loading = false;
        StateHasChanged();
    }

    private void ApplyFilters()
    {
        var query = _students.AsEnumerable();

        // Filter by Course
        if (!string.IsNullOrEmpty(_selectedCourse))
        {
            query = query.Where(s => s.Course == _selectedCourse);
        }

        // Filter by Year Level
        if (_selectedYearLevel > 0)
        {
            query = query.Where(s => s.YearLevel == _selectedYearLevel);
        }

        _filteredStudents = query.ToList();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        _selectedCourse = "";
        _selectedYearLevel = 0;
        ApplyFilters();
        Snackbar.Add("Filters cleared", Severity.Info);
    }

    private async Task SaveAllStudents()
    {
        if (_filteredStudents.Count == 0) return;

        _loading = true;
        StateHasChanged();

        int savedCount = 0;

        foreach (var student in _filteredStudents)
        {
            var result = await EligibilityService.SaveRegistrarEligibilityAsync(student);
            if (result.Status == 200) savedCount++;
        }

        _loading = false;
        Snackbar.Add($"Saved {savedCount} students", savedCount > 0 ? Severity.Success : Severity.Error);
        StateHasChanged();
    }
}