@page "/admin"
@layout MainLayout
@inject StudentsService StudentsService
@inject EnrollmentService EnrollmentService
@inject DocumentsService DocumentsService
@inject NavigationManager nav

<PageTitle>Admin Dashboard</PageTitle>

<!-- Welcome Banner -->
<MudPaper Elevation="0" Style="background:linear-gradient(135deg,#132d6e 0%,#1e3a8a 100%); border-radius:16px; padding:28px 32px; margin-bottom:28px; overflow:hidden; position:relative;">
    <MudStack Spacing="1">
        <MudText Typo="Typo.h5" Style="color:#ffffff; font-weight:700;">Good day, Administrator 👋</MudText>
        <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.65);">Here's what's happening in your system today.</MudText>
    </MudStack>
</MudPaper>

@if (_loading)
{
    <MudGrid Spacing="3" Class="mb-6">
        @for (int i = 0; i < 3; i++)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="120px" Style="border-radius:14px;" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="3" Style="border-radius:14px; background:linear-gradient(135deg,#1565c0,#1e88e5); padding:24px; min-height:120px; position:relative; overflow:hidden;">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.8px; font-size:11px; font-weight:600;">Total Students</MudText>
                    <MudText Typo="Typo.h3" Style="color:#ffffff; font-weight:800; line-height:1;">@_totalStudents</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.School" Style="position:absolute; right:16px; bottom:16px; font-size:3.5rem; color:rgba(255,255,255,0.12);" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="3" Style="border-radius:14px; background:linear-gradient(135deg,#c62828,#e53935); padding:24px; min-height:120px; position:relative; overflow:hidden;">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.8px; font-size:11px; font-weight:600;">Pending Enrollments</MudText>
                    <MudText Typo="Typo.h3" Style="color:#ffffff; font-weight:800; line-height:1;">@_pendingEnrollments</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.HowToReg" Style="position:absolute; right:16px; bottom:16px; font-size:3.5rem; color:rgba(255,255,255,0.12);" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="3" Style="border-radius:14px; background:linear-gradient(135deg,#e65100,#f57c00); padding:24px; min-height:120px; position:relative; overflow:hidden;">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.8px; font-size:11px; font-weight:600;">Pending Documents</MudText>
                    <MudText Typo="Typo.h3" Style="color:#ffffff; font-weight:800; line-height:1;">@_pendingDocs</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.Description" Style="position:absolute; right:16px; bottom:16px; font-size:3.5rem; color:rgba(255,255,255,0.12);" />
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    bool _loading = true;
    int _totalStudents, _pendingEnrollments, _pendingDocs;

    protected override async Task OnInitializedAsync()
    {
        var students = await StudentsService.GetAllStudentsAsync();
        var enrollments = await EnrollmentService.GetPendingEnrollmentsAsync();
        var docs = await DocumentsService.GetAllDocumentsAsync();

        if (students.Status == 200) _totalStudents = students.Data?.Count ?? 0;
        if (enrollments.Status == 200) _pendingEnrollments = enrollments.Data?.Count ?? 0;
        if (docs.Status == 200) _pendingDocs = docs.Data?.Count(d => !d.IsApproved) ?? 0;
        _loading = false;
    }
}