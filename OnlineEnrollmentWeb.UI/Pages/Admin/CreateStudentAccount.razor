@page "/admin/create-student-account"
@layout MainLayout
@inject AuthService AuthService
@inject ISnackbar Snackbar
@inject NavigationManager nav

<PageTitle>Create Student Account</PageTitle>

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="10" md="7" lg="5">

        <!-- Header Card -->
        <MudPaper Elevation="0" Style="background:linear-gradient(135deg,#132d6e 0%,#1e3a8a 100%); border-radius:20px 20px 0 0; padding:32px 36px 28px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Style="background:rgba(255,255,255,0.15); width:52px; height:52px;">
                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="color:#ffffff; font-size:1.6rem;" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Style="color:#ffffff; font-weight:700; line-height:1.2;">Create Student Account</MudText>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.6); font-size:13px;">Fill in the details to register a new student</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- Form Card -->
        <MudPaper Elevation="3" Style="border-radius:0 0 20px 20px; padding:36px; background:#ffffff;">

            <MudStack Spacing="4">

                <!-- Student ID -->
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Style="color:#132d6e; font-weight:600; font-size:13px;">Student ID</MudText>
                    <MudTextField @bind-Value="_req.StudentID"
                                  Placeholder="e.g. 2024-00001"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Badge"
                                  AdornmentColor="Color.Primary"
                                  Style="border-radius:10px;" />
                </MudStack>

                <!-- Username -->
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Style="color:#132d6e; font-weight:600; font-size:13px;">Username (Student Number)</MudText>
                    <MudTextField @bind-Value="_req.Username"
                                  Placeholder="e.g. 2024-00001"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person"
                                  AdornmentColor="Color.Primary"
                                  Style="border-radius:10px;" />
                </MudStack>

                <!-- Password -->
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Style="color:#132d6e; font-weight:600; font-size:13px;">Password</MudText>
                    <MudTextField @bind-Value="_req.Password"
                                  Placeholder="Enter a strong password"
                                  Variant="Variant.Outlined"
                                  InputType="@_passwordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_passwordIcon"
                                  OnAdornmentClick="TogglePassword"
                                  AdornmentColor="Color.Default"
                                  Style="border-radius:10px;" />
                </MudStack>

                <!-- Alert -->
                @if (_statusCode != 0)
                {
                    <MudAlert Severity="@_severity"
                              Style="border-radius:10px;"
                              ShowCloseIcon="true"
                              CloseIconClicked="() => _statusCode = 0">
                        @_message
                    </MudAlert>
                }

                <!-- Divider -->
                <MudDivider Style="border-color:#e8edf5;" />

                <!-- Actions -->
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                    <MudButton Variant="Variant.Outlined"
                               Style="border-radius:10px; border-color:#e2e8f4; color:#6b7a99; text-transform:none; font-weight:600; padding:8px 24px;"
                               OnClick="ResetForm"
                               Disabled="_loading">
                        Clear
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Style="border-radius:10px; background:linear-gradient(135deg,#132d6e,#1e3a8a); color:#ffffff; text-transform:none; font-weight:600; padding:8px 32px; box-shadow:0 4px 14px rgba(19,45,110,0.3);"
                               OnClick="HandleCreate"
                               Disabled="_loading">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" Style="color:#ffffff;" />
                            <span>Creating...</span>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" Style="font-size:1rem;" />
                            <span>Create Account</span>
                        }
                    </MudButton>
                </MudStack>

            </MudStack>
        </MudPaper>

        <!-- Info note -->
        <MudPaper Elevation="0" Style="background:#eef2ff; border-radius:10px; padding:14px 18px; margin-top:16px; border:1px solid #c7d2f0;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Info" Style="color:#132d6e; font-size:1.1rem;" />
                <MudText Typo="Typo.body2" Style="color:#132d6e; font-size:12.5px;">
                    The student will use their <strong>username</strong> and <strong>password</strong> to log in to the portal.
                </MudText>
            </MudStack>
        </MudPaper>

    </MudItem>
</MudGrid>

@code {
    CreateStudentRequest _req = new();
    bool _loading;
    int _statusCode;
    string _message = string.Empty;
    Severity _severity = Severity.Success;

    InputType _passwordInput = InputType.Password;
    string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    void TogglePassword()
    {
        if (_passwordInput == InputType.Password)
        {
            _passwordInput = InputType.Text;
            _passwordIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            _passwordInput = InputType.Password;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    void ResetForm()
    {
        _req = new();
        _statusCode = 0;
        _message = string.Empty;
    }

    async Task HandleCreate()
    {
        _loading = true;
        _statusCode = 0;
        var r = await AuthService.CreateStudentAccountAsync(_req);
        _statusCode = r.Status;
        _message = r.Message;
        _severity = r.Status == 200 ? Severity.Success
                  : r.Status == 400 ? Severity.Warning
                  : Severity.Error;
        if (r.Status == 200) _req = new();
        _loading = false;
    }
}