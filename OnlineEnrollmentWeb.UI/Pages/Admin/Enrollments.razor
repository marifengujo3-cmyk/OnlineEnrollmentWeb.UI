@page "/admin/enrollments"
@layout MainLayout
@inject EnrollmentService EnrollmentService
@inject ISnackbar Snackbar

<PageTitle>Enrollment Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Style="padding: 0;">

    <!-- Header -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6" Style="color:#132d6e; font-weight:700;">Enrollment Management</MudText>
            <MudText Typo="Typo.body2" Style="color:#6b7a99;">
                Total: @_filteredTotal enrollment(s) | Showing @_pagedEnrollments.Count of @_filteredTotal
            </MudText>
        </MudStack>
    </MudStack>

    <!-- Stats Cards -->
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Style="padding:16px; text-align:center; background:#eef2ff;">
                <MudText Typo="Typo.h4" Style="color:#132d6e; font-weight:800;">@_allEnrollments.Count(e => e.EnrollmentStatus == "Pending")</MudText>
                <MudText Typo="Typo.body2" Style="color:#132d6e;">Pending</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Style="padding:16px; text-align:center; background:#dcfce7;">
                <MudText Typo="Typo.h4" Style="color:#065F46; font-weight:800;">@_allEnrollments.Count(e => e.EnrollmentStatus == "Approved")</MudText>
                <MudText Typo="Typo.body2" Style="color:#065F46;">Approved</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Style="padding:16px; text-align:center; background:#fee2e2;">
                <MudText Typo="Typo.h4" Style="color:#991b1b; font-weight:800;">@_allEnrollments.Count(e => e.EnrollmentStatus == "Rejected")</MudText>
                <MudText Typo="Typo.body2" Style="color:#991b1b;">Rejected</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Filters -->
    <MudPaper Style="padding:16px; margin-bottom:24px; border-radius:14px;">
        <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <MudTextField @bind-Value="_searchTerm"
                          Placeholder="Search by Name, ID, or Student #..."
                          Variant="Variant.Outlined"
                          Size="Size.Small"
                          Style="min-width:200px; flex:2;"
                          Immediate="true"
                          OnKeyUp="@(() => ApplyFilters())" />

            <select @bind="_selectedStatus" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; background: white; min-width: 130px;">
                <option value="all">All Status</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Rejected">Rejected</option>
            </select>

            <select @bind="_selectedCourse" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; background: white; min-width: 180px;">
                <option value="">All Courses</option>
                <option value="BS Information Technology">BS Information Technology</option>
                <option value="BS Computer Science">BS Computer Science</option>
                <option value="BS Accountancy">BS Accountancy</option>
                <option value="BS Business Administration">BS Business Administration</option>
                <option value="BS Hospitality Management">BS Hospitality Management</option>
            </select>

            <select @bind="_selectedYearLevel" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; background: white; min-width: 130px;">
                <option value="0">All Years</option>
                <option value="1">1st Year</option>
                <option value="2">2nd Year</option>
                <option value="3">3rd Year</option>
                <option value="4">4th Year</option>
            </select>

            <select @bind="_selectedSemester" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; background: white; min-width: 140px;">
                <option value="">All Semesters</option>
                <option value="1st Semester">1st Semester</option>
                <option value="2nd Semester">2nd Semester</option>
            </select>

            <select @bind="_selectedSchoolYear" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 8px; background: white; min-width: 140px;">
                <option value="">All School Years</option>
                <option value="2024-2025">2024-2025</option>
                <option value="2025-2026">2025-2026</option>
                <option value="2026-2027">2026-2027</option>
            </select>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="@ApplyFilters">Apply</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" OnClick="@ClearFilters">Clear</MudButton>
        </div>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!_pagedEnrollments.Any())
    {
        <MudPaper Style="text-align:center; padding:60px; border-radius:14px;">
            <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Large" Style="color:#c7d2f0; font-size:48px;" />
            <MudText Style="color:#6b7a99;">No enrollments found</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="2" Style="border-radius:14px; overflow-x:auto;">
            <MudTable Items="_pagedEnrollments" Hover="true" Style="border-radius:14px; min-width:1000px;">
                <HeaderContent>
                    <MudTh>Student ID</MudTh>
                    <MudTh>Student #</MudTh>
                    <MudTh>Student Name</MudTh>
                    <MudTh>Course</MudTh>
                    <MudTh>Year</MudTh>
                    <MudTh>Semester</MudTh>
                    <MudTh>School Year</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.StudentID</MudTd>
                    <MudTd>@context.StudentNumber</MudTd>
                    <MudTd>@context.FullName</MudTd>
                    <MudTd>@context.Course</MudTd>
                    <MudTd>@context.YearLevel</MudTd>
                    <MudTd>@context.Semester</MudTd>
                    <MudTd>@context.SchoolYear</MudTd>
                    <MudTd>
                        @if (context.EnrollmentStatus == "Pending")
                        {
                            <span style="background:#fff3cd; color:#856404; padding:4px 8px; border-radius:16px; font-size:12px;">Pending</span>
                        }
                        else if (context.EnrollmentStatus == "Approved")
                        {
                            <span style="background:#dcfce7; color:#065F46; padding:4px 8px; border-radius:16px; font-size:12px;">Approved</span>
                        }
                        else
                        {
                            <span style="background:#fee2e2; color:#991b1b; padding:4px 8px; border-radius:16px; font-size:12px;">@context.EnrollmentStatus</span>
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.EnrollmentStatus == "Pending")
                        {
                            <MudStack Row="true" Spacing="1">
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" OnClick="@(() => ApproveEnrollment(context.EnrollmentID))">
                                    Approve
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="@(() => RejectEnrollment(context.EnrollmentID))">
                                    Reject
                                </MudButton>
                            </MudStack>
                        }
                        else
                        {
                            <span style="background:#eef2ff; color:#132d6e; padding:4px 8px; border-radius:16px; font-size:12px;">Processed</span>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <!-- Pagination Controls -->
        <div style="display: flex; justify-content: center; align-items: center; gap: 16px; margin-top: 24px;">
            <MudButton Variant="Variant.Outlined" Size="Size.Medium" OnClick="@(() => ChangePage(_currentPage - 1))" Disabled="@(_currentPage <= 1)">
                ◀ Previous
            </MudButton>

            <span style="font-size: 14px; color: #6b7a99;">
                Page @_currentPage of @_totalPages
            </span>

            <MudButton Variant="Variant.Outlined" Size="Size.Medium" OnClick="@(() => ChangePage(_currentPage + 1))" Disabled="@(_currentPage >= _totalPages)">
                Next ▶
            </MudButton>

            <div style="margin-left: 16px;">
                <select @bind="PageSize" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 8px;">
                    <option value="10">10 per page</option>
                    <option value="20">20 per page</option>
                    <option value="50">50 per page</option>
                    <option value="100">100 per page</option>
                </select>
            </div>
        </div>
    }
</MudContainer>

@code {
    private List<EnrollmentModel> _allEnrollments = new();
    private List<EnrollmentModel> _filteredEnrollments = new();
    private List<EnrollmentModel> _pagedEnrollments = new();
    private bool _loading = true;

    // Filters
    private string _searchTerm = "";
    private string _selectedStatus = "all";
    private string _selectedCourse = "";
    private string _selectedYearLevel = "";
    private string _selectedSemester = "";
    private string _selectedSchoolYear = "";

    // Counts
    private int _filteredTotal = 0;

    // Pagination
    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalPages = 1;

    // Property for page size binding
    private int PageSize
    {
        get => _pageSize;
        set
        {
            if (_pageSize != value)
            {
                _pageSize = value;
                ChangePage(1);
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadEnrollments();
    }

    private async Task LoadEnrollments()
    {
        _loading = true;
        StateHasChanged();

        var result = await EnrollmentService.GetAllEnrollmentsAsync();

        if (result.Status == 200 && result.Data != null)
        {
            _allEnrollments = result.Data;
        }
        else
        {
            _allEnrollments = new List<EnrollmentModel>();
            Snackbar.Add(result.Message ?? "Error loading enrollments", Severity.Error);
        }

        ApplyFilters();
        _loading = false;
        StateHasChanged();
    }

    private void ApplyFilters()
    {
        var query = _allEnrollments.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            query = query.Where(e =>
                e.FullName?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) == true ||
                e.StudentNumber?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) == true ||
                e.StudentID.ToString().Contains(_searchTerm));
        }

        if (_selectedStatus != "all")
        {
            query = query.Where(e => e.EnrollmentStatus == _selectedStatus);
        }

        if (!string.IsNullOrEmpty(_selectedCourse))
        {
            query = query.Where(e => e.Course == _selectedCourse);
        }

        if (!string.IsNullOrEmpty(_selectedYearLevel) && _selectedYearLevel != "0")
        {
            query = query.Where(e => e.YearLevel == _selectedYearLevel);
        }

        if (!string.IsNullOrEmpty(_selectedSemester))
        {
            query = query.Where(e => e.Semester == _selectedSemester);
        }

        if (!string.IsNullOrEmpty(_selectedSchoolYear))
        {
            query = query.Where(e => e.SchoolYear == _selectedSchoolYear);
        }

        _filteredEnrollments = query.OrderByDescending(e => e.EnrollmentID).ToList();
        _filteredTotal = _filteredEnrollments.Count;

        // Calculate total pages
        _totalPages = (int)Math.Ceiling((double)_filteredTotal / _pageSize);

        // Ensure current page is valid
        if (_currentPage > _totalPages && _totalPages > 0)
            _currentPage = _totalPages;
        if (_currentPage < 1)
            _currentPage = 1;

        // Apply pagination
        _pagedEnrollments = _filteredEnrollments
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();

        StateHasChanged();
    }

    private void ChangePage(int newPage)
    {
        if (newPage < 1 || newPage > _totalPages) return;
        _currentPage = newPage;
        ApplyFilters();
    }

    private void ClearFilters()
    {
        _searchTerm = "";
        _selectedStatus = "all";
        _selectedCourse = "";
        _selectedYearLevel = "";
        _selectedSemester = "";
        _selectedSchoolYear = "";
        _currentPage = 1;
        ApplyFilters();
        Snackbar.Add("Filters cleared", Severity.Info);
    }

    private async Task ApproveEnrollment(int id)
    {
        var result = await EnrollmentService.AdminApproveEnrollmentAsync(id);
        if (result.Status == 200)
        {
            Snackbar.Add("Enrollment approved!", Severity.Success);
            await LoadEnrollments();
        }
        else
        {
            Snackbar.Add($"Error: {result.Message}", Severity.Error);
        }
    }

    private async Task RejectEnrollment(int id)
    {
        Console.WriteLine($"Rejecting enrollment ID: {id}");
        var result = await EnrollmentService.AdminRejectEnrollmentAsync(id);
        Console.WriteLine($"Result: {result.Status} - {result.Message}");

        if (result.Status == 200)
        {
            Snackbar.Add("Enrollment rejected!", Severity.Warning);
            await LoadEnrollments();
        }
        else
        {
            Snackbar.Add($"Error: {result.Message}", Severity.Error);
        }
    }
}